# Copy this file to ".env" and fill in your real key.
# The .env file is git-ignored so your key never gets committed.

# Your OpenRouter API key (get one at https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Which model to use. "openrouter/free" auto-picks a working FREE model (no cost).
OPENROUTER_MODEL=openrouter/free
